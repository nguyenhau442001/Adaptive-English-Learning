# Copy this file to .env at the repo root and fill in real values.
# One root .env is read by both the Next.js app (apps/web/next.config.ts)
# and the seed script (packages/exam-profiles/toeic/src/seed.ts) — no need
# to duplicate it. apps/web/.env.local also works and takes precedence if
# you'd rather keep it Next-convention-only.
#
# This app is entirely free to run: Supabase's free tier covers Postgres +
# Auth, and Speaking/Writing grading + error classification are rule-based
# (see apps/web/src/lib/text-metrics.ts) — no paid AI API is required.

# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase project settings -> API -> service_role (secret!). Only used by
# the seed script (packages/exam-profiles/toeic) to import content, since
# that import bypasses RLS by design. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
